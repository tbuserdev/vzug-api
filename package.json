{
  "name": "vzug",
  "description": "Bun-based HTTP controller for a V-Zug display clock with scheduled automation and manual endpoints.",
  "license": "MIT",
  "author": "Tim Buser <hello@tbuser.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbuserdev/vzug-api.git"
  },
  "bugs": {
    "url": "https://github.com/tbuserdev/vzug-api/issues"
  },
  "homepage": "https://github.com/tbuserdev/vzug-api#readme",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun run --watch index.ts",
    "build": "bun build index.ts --outdir ./build --target node",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run build",
    "docker:build": "docker build -t vzug-api ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "cron": "^4.4.0"
  }
}
