BASE_URL=http://device.local
PORT=3000
HOST_PORT=9999
ALLOW_INSECURE_TLS=false
HTTP_TIMEOUT=10s
RETRY_COUNT=3
RETRY_DELAY=5s
TIMEZONE=Europe/Zurich
SHOW_SCHEDULE="0 22 * * *"
HIDE_SCHEDULE="0 6 * * *"

# Required for Home Assistant MQTT discovery.
MQTT_BROKER=tcp://homeassistant.local:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=vzug-ha
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_BASE_TOPIC=vzug/display_clock
DEVICE_ID=vzug_display_clock
DEVICE_NAME=V-ZUG Display Clock
